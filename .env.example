# Dayliff 1000 Eyes — Environment variables example
# Copy this file to .env and fill in the values

# ─── Server ────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info

# ─── Database ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://dayliff:dayliff_dev@localhost:5432/dayliff_eyes

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT (RS256) ───────────────────────────────────────────────────────────
# Generate keys: openssl genrsa -out private.pem 2048 && openssl rsa -in private.pem -pubout -out public.pem
# Then base64-encode: base64 -w 0 private.pem
JWT_PRIVATE_KEY=<base64-encoded-RS256-private-key-PEM>
JWT_PUBLIC_KEY=<base64-encoded-RS256-public-key-PEM>
JWT_ACCESS_EXPIRY_SECONDS=900
JWT_REFRESH_EXPIRY_SECONDS=604800

# ─── ML Service ────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000

# ─── CORS ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
